  <section class="section">
    <div class="container contact-grid">
      <article class="contact-card">
        <h2>Detalii restaurant</h2>
        <div class="contact-row"><strong>Adresă</strong><span>Prundu Bârgăului, Bistrița-Năsăud</span></div>
        <div class="contact-row"><strong>Telefon</strong><span>07xx xxx xxx</span></div>
        <div class="contact-row"><strong>Instagram</strong><span>@rivo.bistro.cafe</span></div>
        <div class="contact-row"><strong>Facebook</strong><span>Rivo Bistro Cafe</span></div>
      </article>

      <article class="contact-card">
        <h2>Program</h2>
        <div class="contact-row"><strong>Luni - Joi</strong><span>09:00 - 22:00</span></div>
        <div class="contact-row"><strong>Vineri - Sâmbătă</strong><span>09:00 - 00:00</span></div>
        <div class="contact-row"><strong>Duminică</strong><span>10:00 - 22:00</span></div>
      </article>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-wrap">
      <span>Rivo Bistro Cafe — Prundu Bârgăului</span>
      <span>Preparat la minut • Ambient premium • Experiență memorabilă</span>
    </div>
  </footer>
