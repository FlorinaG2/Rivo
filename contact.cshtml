<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact | Rivo Bistro Cafe</title>
  <meta name="description" content="Contact Rivo Bistro Cafe." />
  <link rel="stylesheet" href="style.css" />
