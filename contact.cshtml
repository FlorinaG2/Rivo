<body>
  <header class="site-header">
    <div class="container nav">
      <a href="index.html" class="brand">
        <img src="Logo.png" alt="Rivo Bistro Cafe" />
        <div>
          <strong>Rivo Bistro Cafe</strong>
          <span>Prundu Bârgăului</span>
        </div>
      </a>

      <nav class="nav-links">
        <a href="index.html">Acasă</a>
        <a href="food-menu.html">Preparate</a>
        <a href="drinks-menu.html">Băuturi</a>
        <a href="gallery.html">Galerie</a>
        <a href="contact.html" class="active nav-cta">Contact</a>
      </nav>
    </div>
  </header>

  <main class="page-hero">
    <div class="container narrow">
      <span class="eyebrow">Contact</span>
      <h1>Te așteptăm la Rivo Bistro Cafe.</h1>
      <p>Un loc creat pentru gust, confort și experiențe memorabile.</p>
